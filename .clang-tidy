# HoshiOS clang-tidy configuration
# OS-kernel-friendly: no magic-number complaints, no malloc/free checks,
# allows fixed MMIO addresses, reserved identifiers (__bss_*), and infinite halts.
#
# Run: clang-tidy -p build/ <source.c> --
#   or: make tidy

Checks: >
  bugprone-*,
  -bugprone-easily-swappable-parameters,
  -bugprone-narrowing-conversions,
  -bugprone-reserved-identifier,
  -bugprone-unused-return-value,
  readability-*,
  -readability-magic-numbers,
  -readability-function-cognitive-complexity,
  -readability-identifier-length,
  -readability-identifier-naming,
  -readability-avoid-const-params-in-decls,
  misc-*,
  -misc-include-cleaner,
  -misc-const-correctness,
  performance-*,
  -performance-no-int-to-ptr,
  -clang-analyzer-core.FixedAddressDereference

CheckOptions:
  - key: readability-function-size.LineThreshold
    value: 80
  - key: readability-function-size.StatementThreshold
    value: 120
  - key: readability-function-size.BranchThreshold
    value: 30
  - key: readability-function-size.VariableThreshold
    value: 20
  - key: readability-function-size.ParameterThreshold
    value: 6
  - key: readability-suspicious-call-argument.PrefixSimilarAbove
    value: 60
  - key: bugprone-argument-comment.StrictMode
    value: false
  - key: misc-throw-by-value-catch-by-reference.CheckThrowTemporaries
    value: false
